{
  "name": "@ffs-cli/ffs",
  "version": "0.1.0",
  "private": false,
  "description": "ffs — code-aware file search CLI. Replaces find/fd/grep/rg/glob/cat with token-budget aware output.",
  "bin": {
    "ffs": "./bin/ffs.cjs"
  },
  "files": [
    "bin",
    "scripts",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "test": "node bin/ffs.cjs --version"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "cpu": [
    "x64",
    "arm64"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmtrKovalenko/ffs.nvim.git",
    "directory": "packages/ffs"
  },
  "keywords": [
    "ffs",
    "cli",
    "file-finder",
    "fuzzy-search",
    "grep",
    "find",
    "fd",
    "ripgrep",
    "code-search",
    "tree-sitter",
    "agent-tools",
    "rust"
  ],
  "author": "Dmitry Kovalenko",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "bugs": {
    "url": "https://github.com/dmtrKovalenko/ffs.nvim/issues"
  },
  "homepage": "https://github.com/dmtrKovalenko/ffs.nvim#readme"
}
